---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

// Informações do Imóvel para facilitar manutenção
const imovel = {
    titulo: "A Tradicional Fazenda dos Pastéis de Belém",
    preco: "Sob Consulta",
    categoria: "Oportunidade de Investimento",
    endereco: "Rod. Santos Dumont, 495 - km 103 - Parque Silvestre, Guapimirim - RJ",
    whatsapp: "5521995676537",
    mensagem_zap: "Olá! Vi o anúncio da Fazenda dos Pastéis de Belém no emguapi.com e gostaria de mais informações."
};
---

<Layout 
    title={`${imovel.titulo} | Classificados emguapi`}
    description="Oportunidade para investidores na subida de Teresópolis. Ideal para SPA, Pousada ou Moradia."
    image="/fotos/PHOTO-2026-04-09-10-24-01.jpg"
>
    <Navbar />

    <main class="max-w-5xl mx-auto p-4 md:p-6 my-8">
        
        <a href="/classificados" class="inline-flex items-center text-sm font-bold text-gray-500 hover:text-navy-base transition-colors mb-6 uppercase tracking-widest">
            &larr; Voltar para Classificados
        </a>

        <div class="mb-8">
            <span class="bg-yellow-400 text-yellow-900 text-xs font-black px-3 py-1 rounded-sm uppercase tracking-widest shadow-sm inline-block mb-3">
                Destaque Premium
            </span>
            <h1 class="text-3xl md:text-5xl font-black text-navy-dark dark:text-white leading-tight mb-4">
                {imovel.titulo}
            </h1>
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-gray-200 dark:border-white/10 pb-6">
                <p class="text-gray-600 dark:text-gray-400 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-base shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    {imovel.endereco}
                </p>
                <div class="text-2xl md:text-3xl font-black text-green-600 dark:text-green-400">
                    {imovel.preco}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-2 space-y-8">
                
                <div class="relative w-full h-80 md:h-[450px] rounded-lg overflow-hidden shadow-md border border-gray-100 dark:border-white/10 bg-gray-100 dark:bg-[#1a2b4c] group">
                    <div id="slider-track" class="flex w-full h-full transition-transform duration-500 ease-in-out">
                        <div class="w-full h-full shrink-0 relative">
                            <img src="/fotos/PHOTO-2026-04-09-10-24-01.jpg" alt="Fachada" class="w-full h-full object-cover" />
                        </div>
                        <div class="w-full h-full shrink-0 relative">
                            <img src="/fotos/PHOTO-2026-04-09-10-24-02.jpg" alt="Varanda e área externa" class="w-full h-full object-cover" />
                        </div>
                        <div class="w-full h-full shrink-0 relative">
                            <img src="/fotos/PHOTO-2026-04-09-10-45-41.jpg" alt="Vista lateral e lagos" class="w-full h-full object-cover" />
                        </div>
                    </div>
                    
                    <button id="btn-prev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-navy-base hover:bg-red-base text-white p-3 rounded-full transition-all duration-300 shadow-[0_0_15px_rgba(0,0,0,0.5)] border-2 border-white z-10 hover:scale-110" aria-label="Imagem anterior">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                    </button>
                    
                    <button id="btn-next" class="absolute right-4 top-1/2 -translate-y-1/2 bg-navy-base hover:bg-red-base text-white p-3 rounded-full transition-all duration-300 shadow-[0_0_15px_rgba(0,0,0,0.5)] border-2 border-white z-10 hover:scale-110" aria-label="Próxima imagem">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                    </button>

                    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10 bg-black/40 px-4 py-2 rounded-full backdrop-blur-sm shadow-md">
                        <button class="dot w-8 h-3 bg-yellow-400 rounded-full shadow-sm transition-all duration-300" aria-label="Ir para imagem 1"></button>
                        <button class="dot w-3 h-3 bg-white/80 hover:bg-white rounded-full shadow-sm transition-all duration-300" aria-label="Ir para imagem 2"></button>
                        <button class="dot w-3 h-3 bg-white/80 hover:bg-white rounded-full shadow-sm transition-all duration-300" aria-label="Ir para imagem 3"></button>
                    </div>
                </div>

                <div class="bg-white dark:bg-[#1a2b4c] p-6 md:p-8 rounded-sm shadow-sm border border-gray-100 dark:border-white/5">
                    <h2 class="text-xl font-black uppercase tracking-tighter text-navy-dark dark:text-white mb-6 flex items-center gap-3">
                        <span class="w-2 h-6 bg-navy-base inline-block rounded-sm"></span>
                        Sobre a Propriedade
                    </h2>
                    
                    <div class="prose prose-lg dark:prose-invert max-w-none text-gray-700 dark:text-gray-300">
                        <p>Você procura o local perfeito para um empreendimento de sucesso ou um refúgio espetacular para morar? Apresentamos a belíssima sede da <strong>Fazenda dos Pastéis de Belém</strong>, o ponto turístico mais tradicional da subida de Teresópolis há mais de 60 anos!</p>
                        <p>Esta é a chance de ouro para finalizar um projeto incrível e dar vida a um negócio altamente rentável ou à casa dos seus sonhos, em uma localização privilegiada.</p>
                        <h3 class="text-navy-dark dark:text-white font-bold mt-8 mb-4">Destaques da Propriedade:</h3>
                        <ul class="space-y-3">
                            <li><strong>🏨 Potencial para SPA de Luxo ou Pousada:</strong> Conta com 7 suítes espaçosas, prontas para serem finalizadas e receberem seus hóspedes com o máximo conforto.</li>
                            <li><strong>🛍️ Estrutura Comercial no Térreo:</strong> Amplo espaço ideal para restaurante, sorveteria e loja de presentes/souvenirs.</li>
                            <li><strong>🍃 Natureza Exuberante:</strong> O terreno é um verdadeiro paraíso, contando com dois lindos lagos e um riacho de água potável.</li>
                            <li><strong>📍 Localização Estratégica:</strong> De frente para a rodovia na famosa subida de Teresópolis, garantindo alto fluxo de turistas e visibilidade inigualável.</li>
                        </ul>
                    </div>
                </div>

                <div class="bg-white dark:bg-[#1a2b4c] p-6 md:p-8 rounded-sm shadow-sm border border-gray-100 dark:border-white/5">
                    <h2 class="text-xl font-black uppercase tracking-tighter text-navy-dark dark:text-white mb-2 flex items-center gap-3">
                        <span class="w-2 h-6 bg-green-500 inline-block rounded-sm"></span>
                        Localização
                    </h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">{imovel.endereco}</p>
                    
                    <div class="relative w-full h-64 md:h-96 rounded-lg overflow-hidden shadow-inner border border-gray-200 dark:border-white/10">
                        <iframe 
                            src="https://maps.google.com/maps?q=Fazenda+dos+Pasteis+de+Belem,+Guapimirim+-+RJ&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                            width="100%" 
                            height="100%" 
                            style="border:0;" 
                            allowfullscreen="" 
                            loading="lazy" 
                            referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>

                <div class="bg-navy-dark p-6 md:p-10 rounded-xl shadow-lg border border-navy-base flex flex-col items-center justify-center text-center">
                    <h2 class="text-2xl font-black uppercase tracking-tighter text-white mb-3">
                        Tour em Vídeo
                    </h2>
                    <p class="text-blue-200 text-sm mb-8 max-w-md">Confira os detalhes desta propriedade exclusiva no vídeo.</p>
                    
                    <div class="relative w-full max-w-[320px] aspect-[9/16] rounded-2xl overflow-hidden shadow-2xl border-4 border-white/10 bg-black">
                        <video 
                            src="/fotos/PHOTO-2026-04-09-10-45-42.mov" 
                            controls 
                            class="absolute top-0 left-0 w-full h-full object-cover"
                            poster="/fotos/PHOTO-2026-04-09-10-24-01.jpg"
                        >
                            O seu navegador não suporta a tag de vídeo.
                        </video>
                    </div>
                </div>

            </div>

            <div class="lg:col-span-1">
                <div class="sticky top-24 bg-white dark:bg-[#1a2b4c] p-6 rounded-sm shadow-lg border border-gray-200 dark:border-white/10">
                    <div class="text-center mb-6">
                        <div class="w-20 h-20 bg-gray-200 rounded-full mx-auto mb-4 overflow-hidden border-2 border-navy-base p-1">
                            <div class="w-full h-full bg-navy-base rounded-full flex items-center justify-center text-white">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            </div>
                        </div>
                        <h3 class="font-black text-lg text-navy-dark dark:text-white">Direto com o Proprietário</h3>
                        <p class="text-sm text-gray-500 mb-2">Venda particular</p>
                        <div class="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 font-bold py-1 px-3 rounded text-sm inline-block">
                            Responde rápido
                        </div>
                    </div>

                    <hr class="border-gray-100 dark:border-white/10 mb-6" />

                    <a href={`https://wa.me/${imovel.whatsapp}?text=${imovel.mensagem_zap}`} target="_blank" class="w-full flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-black py-4 px-6 rounded-sm transition-colors shadow-md text-lg mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                        (21) 99567-6537
                    </a>
                </div>
            </div>

        </div>
    </main>
</Layout>

<script>
    // Lógica do Carrossel de Imagens
    const track = document.getElementById('slider-track');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    const dots = document.querySelectorAll('.dot');
    
    let currentIndex = 0;
    const totalSlides = 3;

    function updateSlider() {
        if (!track) return;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        
        dots.forEach((dot, index) => {
            if (index === currentIndex) {
                dot.classList.remove('bg-white/80', 'w-3');
                dot.classList.add('bg-yellow-400', 'w-8');
            } else {
                dot.classList.remove('bg-yellow-400', 'w-8');
                dot.classList.add('bg-white/80', 'w-3');
            }
        });
    }

    if (btnNext && btnPrev) {
        btnNext.addEventListener('click', () => {
            currentIndex = (currentIndex + 1) % totalSlides;
            updateSlider();
        });

        btnPrev.addEventListener('click', () => {
            currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
            updateSlider();
        });
    }

    // Permitir clique nos pontos
    dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
            currentIndex = index;
            updateSlider();
        });
    });
</script>