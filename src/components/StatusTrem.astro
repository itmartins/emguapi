---
// src/components/StatusTrem.astro
import fs from 'node:fs';
import path from 'node:path';

let statusData = { estado: 'indisponivel', ultimaAtualizacao: '--:--' };
try {
    const filePath = path.join(process.cwd(), 'public', 'api', 'trem.json');
    if (fs.existsSync(filePath)) {
        statusData = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
} catch (e) {
    console.error("Erro ao ler /api/trem.json no servidor:", e);
}

const { estado, ultimaAtualizacao } = statusData;

// Configuração padrão de Servidor (Fallback inicial)
let config = {
    bg: "bg-green-600",
    border: "border-green-400",
    titulo: "Operação Normal",
    texto: "Trens circulando conforme a grade horária prevista.",
    luzCor: "bg-green-400", 
    luzGlow: "shadow-green-300", 
    bgIcone: "bg-green-700/30",
    key: "normal"
};

const key = (estado || 'indisponivel').toLowerCase();
switch (key) {
    case 'atrasado':
        config = { bg: "bg-yellow-500", border: "border-yellow-300", titulo: "Operação com Atrasos", texto: "Intervalos irregulares devido a ocorrências operacionais.", luzCor: "bg-yellow-200", luzGlow: "shadow-yellow-100", bgIcone: "bg-yellow-700/30", key }; break;
    case 'suspenso':
        config = { bg: "bg-red-base", border: "border-red-400", titulo: "Operação Suspensa", texto: "Circulação interrompida temporariamente no ramal.", luzCor: "bg-red-200", luzGlow: "shadow-red-900", bgIcone: "bg-red-900/30", key }; break;
    case 'manutencao':
        config = { bg: "bg-navy-base", border: "border-navy-soft", titulo: "Manutenção Programada", texto: "A circulação será normalizada na segunda-feira, na primeira viagem do dia.", luzCor: "bg-blue-300", luzGlow: "shadow-blue-200", bgIcone: "bg-blue-900/30", key }; break;
    case 'parcial':
        config = { bg: "bg-orange-500", border: "border-orange-400", titulo: "Operação Parcial", texto: "A circulação está indo apenas até Magé.", luzCor: "bg-orange-200", luzGlow: "shadow-orange-100", bgIcone: "bg-orange-800/30", key }; break;
    case 'indisponivel':
        config = { bg: "bg-gray-500", border: "border-gray-400", titulo: "Sem Informação", texto: "Não foi possível obter o status da operação no momento.", luzCor: "bg-gray-300", luzGlow: "shadow-gray-200", bgIcone: "bg-gray-700/30", key }; break;
}
---

<div id="st-main-bg" class={`rounded-[2rem] p-6 ${config.bg} text-white shadow-xl flex flex-col md:flex-row items-center gap-6 border-4 ${config.border} relative overflow-hidden group hover:scale-[1.01] transition-all duration-500`}>
    
    <div class="absolute -right-16 -top-16 w-64 h-64 rounded-full bg-white/5 pointer-events-none blur-3xl"></div>

    <div id="st-icon-bg" class={`w-24 h-24 rounded-full flex items-center justify-center shadow-inner backdrop-blur-sm z-10 border border-white/10 transition-colors duration-500 ${config.bgIcone}`}>
        <span id="st-ping-wrapper" class={`relative flex h-8 w-8 ${config.key === 'indisponivel' ? 'hidden' : ''}`}>
            <span id="st-ping-anim" class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${config.luzCor}`}></span>
            <span id="st-ping-dot" class={`relative inline-flex rounded-full h-8 w-8 shadow-[0_0_15px_rgba(255,255,255,0.6)] ${config.luzCor}`}></span>
        </span>
    </div>

    <div class="flex-1 text-center md:text-left z-10">
        <h3 id="st-titulo" class="text-xl font-black uppercase italic tracking-tighter mb-2 text-white drop-shadow-md transition-all duration-500">
            Status: {config.titulo}
        </h3>
        <p id="st-texto" class="font-medium leading-tight opacity-95 text-sm md:text-base transition-all duration-500">{config.texto}</p>
        
        <div class="mt-4 flex items-center justify-center md:justify-start gap-2 opacity-70">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z" clip-rule="evenodd" />
            </svg>
            <p id="st-hora" class="text-[10px] font-black uppercase tracking-widest transition-all duration-500">
                Atualizado: {ultimaAtualizacao}
            </p>
        </div>
    </div>
</div>

<script is:inline>
    function atualizarStatusComponente() {
        console.log("🚂 [StatusTrem] A verificar estado na API...");
        
        fetch('/api/trem.json?v=' + new Date().getTime())
            .then(response => response.json())
            .then(data => {
                console.log("✅ [StatusTrem] Dados recebidos:", data);

                const configVisual = {
                    'normal': { bg: 'bg-green-600', border: 'border-green-400', titulo: 'Operação Normal', texto: 'Trens circulando conforme a grade horária prevista.', luzCor: 'bg-green-400', bgIcone: 'bg-green-700/30' },
                    'atrasado': { bg: 'bg-yellow-500', border: 'border-yellow-300', titulo: 'Operação com Atrasos', texto: 'Intervalos irregulares devido a ocorrências operacionais.', luzCor: 'bg-yellow-200', bgIcone: 'bg-yellow-700/30' },
                    'suspenso': { bg: 'bg-red-base', border: 'border-red-400', titulo: 'Operação Suspensa', texto: 'Circulação interrompida temporariamente no ramal.', luzCor: 'bg-red-200', bgIcone: 'bg-red-900/30' },
                    'manutencao': { bg: 'bg-navy-base', border: 'border-navy-soft', titulo: 'Manutenção Programada', texto: 'A circulação será normalizada na segunda-feira, na primeira viagem do dia.', luzCor: 'bg-blue-300', bgIcone: 'bg-blue-900/30' },
                    'parcial': { bg: 'bg-orange-500', border: 'border-orange-400', titulo: 'Operação Parcial', texto: 'A circulação está indo apenas até Magé.', luzCor: 'bg-orange-200', bgIcone: 'bg-orange-800/30' },
                    'indisponivel': { bg: 'bg-gray-500', border: 'border-gray-400', titulo: 'Sem Informação', texto: 'Não foi possível obter o status da operação no momento.', luzCor: 'bg-gray-300', bgIcone: 'bg-gray-700/30' }
                };

                const key = (data.estado || 'indisponivel').toLowerCase();
                const config = configVisual[key] || configVisual['indisponivel'];

                const mainBg = document.getElementById('st-main-bg');
                if (mainBg) mainBg.className = `rounded-[2rem] p-6 ${config.bg} text-white shadow-xl flex flex-col md:flex-row items-center gap-6 border-4 ${config.border} relative overflow-hidden group hover:scale-[1.01] transition-all duration-500`;

                const iconBg = document.getElementById('st-icon-bg');
                if (iconBg) iconBg.className = `w-24 h-24 rounded-full flex items-center justify-center shadow-inner backdrop-blur-sm z-10 border border-white/10 transition-colors duration-500 ${config.bgIcone}`;

                const tituloEl = document.getElementById('st-titulo');
                if (tituloEl) tituloEl.innerText = 'Status: ' + config.titulo;

                const textoEl = document.getElementById('st-texto');
                if (textoEl) textoEl.innerText = config.texto;

                const horaEl = document.getElementById('st-hora');
                if (horaEl) horaEl.innerText = 'Atualizado: ' + (data.ultimaAtualizacao || '--:--');

                const pingWrapper = document.getElementById('st-ping-wrapper');
                const pingAnim = document.getElementById('st-ping-anim');
                const pingDot = document.getElementById('st-ping-dot');

                if (key === 'indisponivel') {
                    if (pingWrapper) pingWrapper.classList.add('hidden');
                } else {
                    if (pingWrapper) pingWrapper.classList.remove('hidden');
                    if (pingAnim) pingAnim.className = `animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${config.luzCor}`;
                    if (pingDot) pingDot.className = `relative inline-flex rounded-full h-8 w-8 shadow-[0_0_15px_rgba(255,255,255,0.6)] ${config.luzCor}`;
                }
            })
            .catch(err => console.error("❌ [StatusTrem] Erro:", err));
    }

    // Para acelerar os nossos testes, coloquei a atualizar a cada 10 segundos!
    atualizarStatusComponente();
    setInterval(atualizarStatusComponente, 10000);
</script>